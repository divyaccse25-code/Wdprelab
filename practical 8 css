
body {
    background: linear-gradient(to right, red, blue);
}

h1 {
    text-align: center;
}
.Hero-s {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    padding: 20px;
}
.Hero img {
    width: 200px;
    height: 300px;
    transition: all 0.3s ease; 
    cursor: pointer;
}
.Hero img:hover {
     transform: scale(1.1);
    cursor: pointer;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2); 
}
