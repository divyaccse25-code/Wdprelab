<!DOCTYPE html>
<html>
<body bgcolor="honeydew">

    <!-- 1. Geolocation -->
    <h3>Location</h3>
    <button onclick="navigator.geolocation.getCurrentPosition(p=>alert(p.coords.latitude+','+p.coords.longitude))">Get GPS</button>

    <!-- 2. Web Storage -->
    <h3>Storage</h3>
    <input id="in" placeholder="Type here">
    <button onclick="localStorage.setItem('val', document.getElementById('in').value)">Save</button>
    <button onclick="alert(localStorage.getItem('val'))">Show</button>

    <!-- 3. Drag & Drop -->
    <h3>Drag & Drop</h3>
    <div id="box" draggable="true" ondragstart="e.dataTransfer.setData('t',e.target.id)" style="width:50px; height:50px; background:red;"></div>
    <div ondragover="event.preventDefault()" ondrop="this.appendChild(document.getElementById(event.dataTransfer.getData('t')))" style="width:100px; height:100px; border:1px solid black; margin-top:10px;">Drop Here</div>

</body>
</html>
